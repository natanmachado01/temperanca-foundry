<form class="{{cssClass}}" autocomplete="off">
    <div class="journal-bg">
        <header class="sheet-header">
            <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}"/>
            <div class="header-details">
                <h1 class="charname"><input name="name" type="text" value="{{actor.name}}" placeholder="Nome"/></h1>
                <div class="grid grid-2col">
                    <div class="form-group"><label>Conceito</label><input type="text" name="system.details.conceito" value="{{system.details.conceito}}"/></div>
                    <div class="form-group"><label>XP</label><input type="number" name="system.attributes.xp.value" value="{{system.attributes.xp.value}}"/></div>
                </div>
            </div>
        </header>
        <hr class="divider">

        <div class="sheet-main-content">
            <div class="left-column">
                <h3 class="section-title">Atributos</h3>
                <div class="compact-list">
                    {{#each system.stats as |stat key|}}
                    <div class="stat-row">
                        <label class="rollable" data-key="{{key}}">{{stat.label}}</label>
                        <input type="number" name="system.stats.{{key}}.value" value="{{stat.value}}"/>
                    </div>
                    {{/each}}
                </div>
                <h3 class="section-title">Passivas</h3>
                <div class="compact-list">
                    {{#each system.passivas as |pass key|}}
                    <div class="stat-row">
                        <label class="rollable" data-label="{{pass.label}}" data-bonus="{{pass.value}}" data-attr="fisico">{{pass.label}} <i class="fas fa-dice-d20"></i></label>
                        <input type="number" name="system.passivas.{{key}}.value" value="{{pass.value}}"/>
                    </div>
                    {{/each}}
                </div>
                <h3 class="section-title warning">Estresse</h3>
                <div class="stress-box">
                    <input class="stress-current" type="number" name="system.attributes.estresse.value" value="{{system.attributes.estresse.value}}" min="0" max="{{system.attributes.estresse.max}}">
                    <span class="stress-divider">/</span>
                    <span class="stress-max">{{system.attributes.estresse.max}}</span>
                </div>
                <h3 class="section-title reacoes-title">Reações</h3>
                <div class="reacoes-box">
                    <input class="reacoes-current" type="number" name="system.attributes.reacoes.value" value="{{system.attributes.reacoes.value}}" min="0" max="{{system.attributes.reacoes.max}}">
                    <span class="stress-divider">/</span>
                    <span class="reacoes-max">{{system.attributes.reacoes.max}}</span>
                </div>
                <p class="reacoes-hint">1 + Motoras ({{system.stats.motoras.value}}) = {{system.attributes.reacoes.max}}</p>
            </div>

            <div class="right-column">
               <h3 class="section-title">Limiares de Dano</h3>
                <div class="thresholds">
                    <div class="thresh-group">
                        <label>Maior (Leve)</label>
                        <input type="number" name="system.attributes.limiares.maior" value="{{system.attributes.limiares.maior}}"/>
                    </div>
                    <div class="thresh-group">
                        <label>Grave (Mod.)</label>
                        <input type="number" name="system.attributes.limiares.grave" value="{{system.attributes.limiares.grave}}"/>
                    </div>
                    <div class="thresh-group lethal">
                        <label>Letal (Pé na Cova)</label>
                        <div class="static-val">{{system.attributes.limiares.letal}}</div>
                    </div>
                </div>
                <p class="thresholds-legend">Dano Leve &lt; Limiar Maior | Limiar Maior &le; Dano Moderado. &lt; Limiar Grave | Grave &le; Dano Grave &lt; Limiar Letal | Limiar Letal &le; Dano Letal</p>

                <h3 class="section-title" style="margin-top: 10px;">Redução de Dano</h3>
                <div class="rd-grid">
                    <div class="rd-group">
                        <label title="Dano Físico (Contusão/Corte)"><i class="fas fa-fist-raised"></i> Físico</label>
                        <input type="number" name="system.attributes.rd.fisico" value="{{system.attributes.rd.fisico}}" placeholder="0"/>
                    </div>
                    <div class="rd-group">
                        <label title="Dano Balístico (Tiros)"><i class="fas fa-crosshairs"></i> Balístico</label>
                        <input type="number" name="system.attributes.rd.balistico" value="{{system.attributes.rd.balistico}}" placeholder="0"/>
                    </div>
                    <div class="rd-group">
                        <label title="Dano Elemental (Fogo/Eletricidade)"><i class="fas fa-fire"></i> Elemental</label>
                        <input type="number" name="system.attributes.rd.elemental" value="{{system.attributes.rd.elemental}}" placeholder="0"/>
                    </div>
                    <div class="rd-group">
                        <label title="Dano Sobrenatural (Magia/Entidades)"><i class="fas fa-ghost"></i> Místico</label>
                        <input type="number" name="system.attributes.rd.sobrenatural" value="{{system.attributes.rd.sobrenatural}}" placeholder="0"/>
                    </div>
                </div>

                <h3 class="section-title danger">Condição Física</h3>
                <div class="damage-tracker">
                    
                    <div class="damage-line">
                        <div class="label-group">
                            <label>Machucado</label>
                            <div class="temp-controls">
                                <a class="temp-btn" data-action="minus" data-type="machucado"><i class="fas fa-minus"></i></a>
                                <a class="temp-btn" data-action="plus" data-type="machucado"><i class="fas fa-plus"></i></a>
                            </div>
                        </div>
                        <div class="pips-container">
                            {{#times system.saude.machucado.max}}
                            <a class="pip {{checkPip this ../system.saude.machucado.value}}" data-type="machucado" data-index="{{this}}"></a>
                            {{/times}}
                        </div>
                    </div>

                    <div class="damage-line">
                        <div class="label-group">
                            <label>Ferimento</label>
                            <div class="temp-controls">
                                <a class="temp-btn" data-action="minus" data-type="ferimento"><i class="fas fa-minus"></i></a>
                                <a class="temp-btn" data-action="plus" data-type="ferimento"><i class="fas fa-plus"></i></a>
                            </div>
                        </div>
                        <div class="pips-container">
                            {{#times system.saude.ferimento.max}}
                            <a class="pip {{checkPip this ../system.saude.ferimento.value}}" data-type="ferimento" data-index="{{this}}"></a>
                            {{/times}}
                        </div>
                    </div>

                    <div class="damage-line">
                        <div class="label-group">
                            <label>Trauma</label>
                            <div class="temp-controls">
                                <a class="temp-btn" data-action="minus" data-type="trauma"><i class="fas fa-minus"></i></a>
                                <a class="temp-btn" data-action="plus" data-type="trauma"><i class="fas fa-plus"></i></a>
                            </div>
                        </div>
                        <div class="pips-container">
                            {{#times system.saude.trauma.max}}
                            <a class="pip {{checkPip this ../system.saude.trauma.value}}" data-type="trauma" data-index="{{this}}"></a>
                            {{/times}}
                        </div>
                    </div>

                    <div class="damage-line lethal">
                        <div class="label-group">
                            <label>Letal</label>
                            <div class="temp-controls">
                                <a class="temp-btn" data-action="minus" data-type="letal"><i class="fas fa-minus"></i></a>
                                <a class="temp-btn" data-action="plus" data-type="letal"><i class="fas fa-plus"></i></a>
                            </div>
                        </div>
                        <div class="pips-container">
                            {{#times system.saude.letal.max}}
                            <a class="pip {{checkPip this ../system.saude.letal.value}}" data-type="letal" data-index="{{this}}"></a>
                            {{/times}}
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <nav class="sheet-tabs tabs" data-group="primary">
            <a class="item" data-tab="skills">Habilidades</a>
            <a class="item" data-tab="talents">Talentos & Oculto</a>
            <a class="item" data-tab="inventory">Inventário</a>
        </nav>

        <section class="sheet-body">
            <div class="tab skills" data-group="primary" data-tab="skills">
                <div class="grid grid-2col">
                    <div class="skill-col">
                        <h3>Técnicas</h3>
                        <ul class="skills-list">
                            {{#each tecnicas as |skill key|}}
                            <li class="skill-item">
                                <a class="rollable" data-label="{{skill.label}}" data-bonus="{{skill.value}}" data-attr="{{skill.attr}}">{{skill.label}}</a>
                                <span class="skill-mod">({{skill.attr}})</span>
                                <input type="number" name="system.skills.{{key}}.value" value="{{skill.value}}"/>
                            </li>
                            {{/each}}
                        </ul>
                    </div>
                    <div class="skill-col">
                        <h3>Combate</h3>
                        <ul class="skills-list combat">
                            {{#each combate as |skill key|}}
                            <li class="skill-item">
                                <a class="rollable" data-label="{{skill.label}}" data-bonus="{{skill.value}}" data-attr="{{skill.attr}}">{{skill.label}}</a>
                                <span class="skill-mod">({{skill.attr}})</span>
                                <input type="number" name="system.skills.{{key}}.value" value="{{skill.value}}"/>
                            </li>
                            {{/each}}
                        </ul>
                    </div>
                </div>
            </div>

            <div class="tab talents" data-group="primary" data-tab="talents">
                
                <div class="talents-header flexrow">
                    <h3>Talentos</h3>
                    <a class="add-talent-btn"><i class="fas fa-plus-circle"></i> Adicionar</a>
                </div>
                
                <div class="talents-list">
                    {{#each talentos as |item|}}
                    <div class="talent-card item" data-item-id="{{item._id}}">
                        <div class="talent-header flexrow">
                            <h4 class="item-chat" title="Mostrar no Chat" style="cursor:pointer;"><i class="fas fa-comment-dots"></i> {{item.name}} <span class="tier-badge">T{{item.system.tier}}</span></h4>
                            <div class="item-controls">
                                <a class="item-edit"><i class="fas fa-edit"></i></a>
                                <a class="item-delete"><i class="fas fa-trash"></i></a>
                            </div>
                        </div>
                        <div class="talent-desc">{{{item.system.description}}}</div>
                    </div>
                    {{else}}
                    <p class="empty-msg">Nenhum talento adquirido.</p>
                    {{/each}}
                </div>

                <div class="talents-header flexrow" style="margin-top: 20px; border-color: #500;">
                    <h3 style="color:#500;">Grimório do Oculto</h3>
                    <a class="add-spell-btn" style="background:#500;"><i class="fas fa-skull"></i> Adicionar Feitiço</a>
                </div>

                <div class="talents-list">
                    {{#each feiticos as |item|}}
                    <div class="talent-card item spell-card" data-item-id="{{item._id}}" style="border-left-color: #500;">
                        <div class="talent-header flexrow">
                            <h4 class="item-chat" title="Mostrar no Chat" style="cursor:pointer; color:#500;"><i class="fas fa-comment-dots"></i> {{item.name}}</h4>
                            <div class="item-controls">
                                <a class="cast-spell-btn" title="Conjurar"><i class="fas fa-magic"></i></a>
                                <a class="item-edit"><i class="fas fa-edit"></i></a>
                                <a class="item-delete"><i class="fas fa-trash"></i></a>
                            </div>
                        </div>
                        <div class="talent-desc">{{{item.system.description}}}</div>
                    </div>
                    {{else}}
                    <p class="empty-msg">Nenhum conhecimento oculto.</p>
                    {{/each}}
                </div>
            </div>

                <div class="tab inventory" data-group="primary" data-tab="inventory">
                    
                    <div class="encumbrance">
                        <span class="encumbrance-label">Carga: {{system.attributes.carga.value}} / {{system.attributes.carga.max}}</span>
                        <div class="encumbrance-bar" style="width: {{system.attributes.carga.pct}}%; background: {{#if (gt system.attributes.carga.value system.attributes.carga.max)}}#a00{{else}}#555{{/if}}"></div>
                    </div>

                    <div class="inventory-controls" style="text-align:right; margin-bottom:10px;">
                        <a class="add-item-btn"><i class="fas fa-plus-circle"></i> Adicionar Item</a>
                    </div>

                    <h3>Armas</h3>
                    <div class="item-list">
                        {{#each armas as |item|}}
                        <div class="item flexrow" data-item-id="{{item._id}}">
                            <img src="{{item.img}}" width="24" height="24"/>
                            <h4 class="item-chat" style="cursor:pointer">{{item.name}}</h4>
                            <div class="item-detail">{{item.system.damage}}</div>
                            <div class="item-detail">Dur: {{item.system.durability}}</div>
                            <div class="item-controls">
                                <a class="item-edit"><i class="fas fa-edit"></i></a>
                                <a class="item-delete"><i class="fas fa-trash"></i></a>
                            </div>
                        </div>
                        {{/each}}
                    </div>

                    <h3>Proteções</h3>
                    <div class="item-list">
                        {{#each protecoes as |item|}}
                        <div class="item flexrow" data-item-id="{{item._id}}">
                            <img src="{{item.img}}" width="24" height="24"/>
                            <h4 class="item-chat" style="cursor:pointer">{{item.name}}</h4>
                            <div class="item-detail">Red: {{item.system.reduction}}</div>
                            <div class="item-detail">Dur: {{item.system.durability}}</div>
                            <div class="item-controls"><a class="item-edit"><i class="fas fa-edit"></i></a><a class="item-delete"><i class="fas fa-trash"></i></a></div>
                        </div>
                        {{/each}}
                    </div>

                    <h3>Consumíveis</h3>
                    <div class="item-list">
                        {{#each consumiveis as |item|}}
                        <div class="item flexrow" data-item-id="{{item._id}}">
                            <img src="{{item.img}}" width="24" height="24"/>
                            <h4 class="item-chat" style="cursor:pointer">{{item.name}}</h4>
                            <div class="item-detail">Usos: {{item.system.uses}}</div>
                            <div class="item-controls"><a class="item-edit"><i class="fas fa-edit"></i></a><a class="item-delete"><i class="fas fa-trash"></i></a></div>
                        </div>
                        {{/each}}
                    </div>

                    <h3>Equipamentos & Recursos</h3>
                    <div class="item-list">
                        {{#each equipamentos as |item|}}
                        <div class="item flexrow" data-item-id="{{item._id}}">
                            <img src="{{item.img}}" width="24" height="24"/>
                            <h4 class="item-chat" style="cursor:pointer">{{item.name}}</h4>
                            <div class="item-detail">{{item.system.weight}} Carga</div>
                            <div class="item-controls"><a class="item-edit"><i class="fas fa-edit"></i></a><a class="item-delete"><i class="fas fa-trash"></i></a></div>
                        </div>
                        {{/each}}
                        {{#each recursos as |item|}}
                        <div class="item flexrow" data-item-id="{{item._id}}">
                            <img src="{{item.img}}" width="24" height="24"/>
                            <h4 class="item-chat" style="cursor:pointer">{{item.name}} ({{item.system.quantity}})</h4>
                            <div class="item-controls"><a class="item-edit"><i class="fas fa-edit"></i></a><a class="item-delete"><i class="fas fa-trash"></i></a></div>
                        </div>
                        {{/each}}
                    </div>
                </div>
        </section>
    </div>
</form>