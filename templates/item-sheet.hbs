<form class="{{cssClass}}" autocomplete="off">
    <header class="sheet-header">
        <img src="{{item.img}}" data-edit="img" title="{{item.name}}"/>
        <h1><input name="name" type="text" value="{{item.name}}" placeholder="Nome"/></h1>
    </header>
    
    <div class="sheet-content">
        <div class="grid grid-2col">
            <div class="form-group">
                <label>Peso (Carga)</label>
                <input type="number" name="system.weight" value="{{system.weight}}" step="0.1"/>
            </div>

            {{#if (eq item.type "arma")}}
            <div class="form-group"><label>Dano</label><input type="text" name="system.damage" value="{{system.damage}}"/></div>
            <div class="form-group"><label>Qualidade</label><input type="text" name="system.quality" value="{{system.quality}}"/></div>
            <div class="form-group"><label>Durabilidade</label><input type="number" name="system.durability" value="{{system.durability}}"/></div>
            {{/if}}

            {{#if (eq item.type "protecao")}}
            <div class="form-group"><label>Redução Dano</label><input type="number" name="system.reduction" value="{{system.reduction}}"/></div>
            <div class="form-group"><label>Durabilidade</label><input type="number" name="system.durability" value="{{system.durability}}"/></div>
            <div class="form-group"><label>Bônus Limiar Maior</label><input type="number" name="system.threshold_bonus_major" value="{{system.threshold_bonus_major}}"/></div>
            <div class="form-group"><label>Bônus Limiar Grave</label><input type="number" name="system.threshold_bonus_severe" value="{{system.threshold_bonus_severe}}"/></div>
            {{/if}}

            {{#if (eq item.type "consumivel")}}
            <div class="form-group"><label>Usos Restantes</label><input type="number" name="system.uses" value="{{system.uses}}"/></div>
            {{/if}}

            {{#if (eq item.type "recurso")}}
            <div class="form-group"><label>Quantidade</label><input type="number" name="system.quantity" value="{{system.quantity}}"/></div>
            {{/if}}
        </div>

        <hr>
        <label>Descrição</label>
        {{editor system.description target="system.description" button=true owner=owner editable=editable}}
    </div>
</form>